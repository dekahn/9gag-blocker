{
  "manifest_version": 3,
  "name": "9GAG Click Blocker",
  "version": "1.1",
  "description": "Block unwanted tags on 9GAG.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "9GAG Click Blocker"
  },
  "content_scripts": [
    {
      "matches": ["https://9gag.com/*"],
      "js": ["content.js"]
    }
  ]
}
